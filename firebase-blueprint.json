{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "A product category like Fruits, Vegetables, etc.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the category" },
        "imageUrl": { "type": "string", "format": "url", "description": "Icon or image for the category" },
        "order": { "type": "integer", "description": "Display order" }
      },
      "required": ["name", "imageUrl", "order"]
    },
    "Product": {
      "title": "Product",
      "description": "A grocery item for sale",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "description": { "type": "string", "description": "Product details" },
        "price": { "type": "number", "description": "Price in INR" },
        "discountPrice": { "type": "number", "description": "Discounted price if applicable" },
        "unit": { "type": "string", "description": "e.g., 500g, 1kg, 1 unit" },
        "imageUrl": { "type": "string", "format": "url", "description": "Product image URL" },
        "categoryId": { "type": "string", "description": "Reference to Category ID" },
        "stock": { "type": "integer", "description": "Available quantity" },
        "damagedCount": { "type": "integer", "description": "Number of damaged units reported" },
        "isPopular": { "type": "boolean", "description": "Whether to show in popular section" }
      },
      "required": ["name", "price", "unit", "imageUrl", "categoryId", "stock"]
    },
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email", "description": "User email" },
        "displayName": { "type": "string", "description": "User's full name" },
        "photoURL": { "type": "string", "format": "url", "description": "User's avatar" },
        "address": { "type": "string", "description": "Default delivery address" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "User role" }
      },
      "required": ["uid", "email", "role"]
    },
    "CartItem": {
      "title": "Cart Item",
      "description": "An item in a user's cart",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "Reference to Product ID" },
        "quantity": { "type": "integer", "description": "Number of units" },
        "addedAt": { "type": "string", "format": "date-time", "description": "When it was added" }
      },
      "required": ["productId", "quantity", "addedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A completed purchase",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Reference to User UID" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "number" },
              "quantity": { "type": "integer" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "deliveryAddress": { "type": "string" },
        "pickupLocation": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        }
      },
      "required": ["userId", "items", "totalAmount", "status", "createdAt", "deliveryAddress"]
    },
    "Sale": {
      "title": "Sale",
      "description": "A store sale recorded in POS",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "subtotal": { "type": "number" },
        "gstAmount": { "type": "number" },
        "discount": { "type": "number" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "paymentMethod": { "type": "string", "enum": ["cash", "online"] },
        "paymentId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "adminId": { "type": "string" },
        "type": { "type": "string", "enum": ["store"] }
      },
      "required": ["items", "totalAmount", "paymentMethod", "createdAt", "adminId"]
    },
    "Procurement": {
      "title": "Procurement",
      "description": "Stock procurement record",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "costPrice": { "type": "number" },
        "supplier": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "adminId": { "type": "string" }
      },
      "required": ["productId", "quantity", "createdAt", "adminId"]
    },
    "Rider": {
      "title": "Rider",
      "description": "A delivery partner",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "geohash": { "type": "string" },
        "rating": { "type": "number" },
        "acceptanceRate": { "type": "number" },
        "status": { "type": "string", "enum": ["online", "busy", "offline"] },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "location", "geohash", "status"]
    },
    "AssignmentLog": {
      "title": "Assignment Log",
      "description": "A record of a rider being assigned to an order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "riderId": { "type": "string" },
        "riderName": { "type": "string" },
        "assignedAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["assigned", "rejected", "completed"] },
        "distance": { "type": "number" },
        "eta": { "type": "number" }
      },
      "required": ["orderId", "riderId", "riderName", "assignedAt", "status"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Product categories"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Available products"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/users/{userId}/cart/{cartId}": {
      "schema": "CartItem",
      "description": "User's shopping cart items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders"
    },
    "/store_sales/{saleId}": {
      "schema": "Sale",
      "description": "In-store POS sales"
    },
    "/procurements/{procurementId}": {
      "schema": "Procurement",
      "description": "Inventory procurement records"
    },
    "/riders/{riderId}": {
      "schema": "Rider",
      "description": "Delivery partners"
    },
    "/assignment_logs/{logId}": {
      "schema": "AssignmentLog",
      "description": "Rider assignment history"
    }
  }
}
